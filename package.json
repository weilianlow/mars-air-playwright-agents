{
  "name": "playwright-mcp-server",
  "version": "1.0.0",
  "description": "A Playwright MCP server for browser automation.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "lint": "eslint .",
    "test": "PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers playwright test",
    "test:debug": "PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers playwright test --debug",
    "test:ui": "PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers playwright test --ui",
    "test:headed": "PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers playwright test --headed",
    "test:trace": "PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers playwright test --trace on",
    "codegen": "PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers npx playwright codegen",
    "show-report": "PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers npx playwright show-report",
    "postinstall": "PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers npx playwright install chromium || true"
  },
  "keywords": [],
  "author": "wei lian",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.42.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
